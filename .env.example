# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ytrip

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Conversion
DOWNLOAD_MODE=stream
# DOWNLOAD_MODE=local
TEMP_DIR=./tmp
TEMP_FILE_TTL_HOURS=4
MAX_CONCURRENT_CONVERSIONS=3

# yt-dlp binary path (if not in PATH)
# YTDLP_PATH=/usr/local/bin/yt-dlp
